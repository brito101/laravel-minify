{
  "name": "brito101/laravel-minify",
  "description": "Minify your blade views, html, css and obfuscate js files on the fly. Lightweight minifier for your Laravel project. Laravel 13 compatible version.",
  "keywords": [
    "laravel",
    "laravel13",
    "html-minifier",
    "css-minifier",
    "js-minifier",
    "js-obfuscate"
  ],
  "authors": [
    {
      "name": "Rodrigo Brito",
      "email": "contato@rodrigobrito.dev.br"
    },
    {
      "name": "fahlisaputra",
      "email": "saputra@fahli.net",
      "role": "Original Author"
    }
  ],
  "require": {
    "php": "^8.2 || ^8.3 || ^8.4",
    "illuminate/support": "^10.0 || ^11.0 || ^12.0 || ^13.0",
    "illuminate/http": "^10.0 || ^11.0 || ^12.0 || ^13.0",
    "illuminate/view": "^10.0 || ^11.0 || ^12.0 || ^13.0"
  },
  "license": "MIT",
  "autoload": {
    "files": [
      "src/Helpers.php"
    ],
    "psr-4": {
      "Brito101\\Minify\\": "src/"
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "extra": {
    "laravel": {
      "providers": [
        "Brito101\\Minify\\MinifyServiceProvider"
      ]
    }
  }
}
